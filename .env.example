# ============================================
# zpool Monitor Configuration
# ============================================

# Zpool Configuration
ZPOOL_WALLET=YOUR_WALLET_ADDRESS_HERE
REFRESH_INTERVAL=60

# Alert Thresholds
ALERT_WORKER_OFFLINE=true
ALERT_MIN_BALANCE=0.01
ALERT_HASHRATE_DROP_PERCENT=50

# Discord Notification
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# ntfy Notification
NTFY_ENABLED=false
NTFY_TOPIC=zpool-monitor-abc123
NTFY_SERVER=https://ntfy.sh